---
main_layout: empty
---
[[headers]]
  for = "/*"
  [headers.values]
  Link = "<https://static.llllllllllll.com/andor/fonts/DepartureMono-Regular.woff2>; rel=preload; as=font; type=\"font/woff2\"; crossorigin"
  Strict-Transport-Security = "max-age=31536000; includeSubDomains; preload"
  Cross-Origin-Opener-Policy = "same-origin"
  X-Frame-Options = "SAMEORIGIN"
  Content-Security-Policy = "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src https://static.llllllllllll.com; img-src 'self' https://static.llllllllllll.com; frame-src https://www.youtube-nocookie.com https://player.vimeo.com; connect-src 'self';"
